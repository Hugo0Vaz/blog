---
import { getRelativeLocaleUrl } from "astro:i18n";
import crypto from "node:crypto";

interface Post {
  id: string;
  data: {
    title: string;
    date: Date;
    author?: string;
  };
}

interface Props {
  posts: Post[];
  locale: string;
}

const { posts, locale } = Astro.props;

function commitHash(post: Post): string {
  const slug = post.id.split("/").pop() ?? post.id;
  return crypto.createHash("sha1").update(slug + post.data.title).digest("hex");
}
---

<div class="text-base leading-relaxed" style="font-family: 'Iosevka', monospace;">
  {
    posts.length === 0 ? (
      <p class="text-primary-dim">fatal: no commits yet</p>
    ) : (
      posts.map((post) => {
        const slug = post.id.split("/").pop();
        const url = getRelativeLocaleUrl(locale, `/blog/${slug}`);
        const author = post.data.author ?? "hugo";
        const hash = commitHash(post);

        const date = post.data.date;
        const pad = (n: number) => String(n).padStart(2, "0");
        const day = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"][date.getUTCDay()];
        const month = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                       "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"][date.getUTCMonth()];
        const gitDate = `${day} ${month} ${pad(date.getUTCDate())} ${pad(date.getUTCHours())}:${pad(date.getUTCMinutes())}:${pad(date.getUTCSeconds())} ${date.getUTCFullYear()} +0000`;

        return (
          <a href={url} class="block mb-6 text-white no-underline">
            <span class="text-primary">commit</span>{" "}
            <span class="text-primary">{hash}</span>
            <br />
            Author: Hugo0Vaz &lt;me@hugovaz.dev&gt;
            <br />
            Date:   {gitDate}
            <br /><br />
            <span class="ml-4">
              {post.data.title}
            </span>
          </a>
        );
      })
    )
  }
</div>
