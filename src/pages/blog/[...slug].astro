---
import { getEntry, getCollection, render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "../../layouts/Layout.astro";
import TableOfContents from "../../components/TableOfContents.astro";

const currentLocale = Astro.currentLocale ?? "pt-br";
const otherLocale = currentLocale === "pt-br" ? "en" : "pt-br";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const localePosts = posts
    .filter((p) => p.data.locale === "pt-br")
    .filter((p) => import.meta.env.DEV || !p.data.draft);
  return localePosts.map((post) => ({
    params: { slug: post.id.split("/").pop() },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/404");
}

const postId = `${currentLocale}/${slug}`;
const post = await getEntry("posts", postId);

if (!post || post.data.locale !== currentLocale) {
  return Astro.redirect("/404");
}

if (!import.meta.env.DEV && post.data.draft) {
  return Astro.redirect("/404");
}

const translationId = `${otherLocale}/${slug}`;
let translation = null;
try {
  translation = await getEntry("posts", translationId);
} catch {}

const { Content, headings = [] } = await render(post);

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const hasToc = tocHeadings.length > 0;

const translationUrl = translation
  ? getRelativeLocaleUrl(otherLocale, `/blog/${slug}`)
  : null;
---

<Layout lang={currentLocale} title={post.data.title}>
  <article>
    <h1 class="font-sans text-4xl font-bold">{post.data.title}</h1>
    <p><small>{post.data.date.toLocaleDateString(currentLocale)}</small></p>
    <div class="flex gap-10">
      {hasToc && (
        <aside class="w-52 flex-shrink-0 hidden lg:block">
          <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
            <TableOfContents headings={headings} />
          </div>
        </aside>
      )}
      <div class="flex-1 min-w-0" style="font-family: 'Computer Modern', 'Times New Roman', serif;">
        <Content />
      </div>
    </div>
  </article>
  <div class="flex justify-between items-center mt-8">
    <a href={getRelativeLocaleUrl(currentLocale, "/blog")}>← Back to blog</a>
    {
      translationUrl && (
        <a href={translationUrl}>
          {otherLocale === "pt-br" ? "Ler em português" : "Read in English"}
        </a>
      )
    }
  </div>
</Layout>
