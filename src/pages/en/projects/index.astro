---
import Layout from "../../../layouts/Layout.astro";

const currentLocale = Astro.currentLocale ?? "en";

interface Project {
  name: string;
  description: string;
  url: string;
  tags: string[];
  date: Date;
}

const months = ["jan", "feb", "mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec"];

function fmtDate(d: Date) {
  const day = String(d.getDate()).padStart(2, " ");
  const month = months[d.getMonth()];
  const hh = String(d.getHours()).padStart(2, "0");
  const mm = String(d.getMinutes()).padStart(2, "0");
  return `${day} ${month} ${hh}:${mm}`;
}

const projects: Project[] = [
  {
    name: "blog",
    description: "My personal website and blog built with Astro.",
    url: "https://github.com/Hugo0Vaz/blog",
    tags: ["Astro", "TypeScript", "TailwindCSS"],
    date: new Date("2026-06-06T21:44"),
  },
  {
    name: "DocsDog",
    description: "Documentation's best friend",
    url: "https://docsdog.hugovaz.dev/",
    tags: ["TypeScript", "Documentation"],
    date: new Date("2026-06-11T20:17"),
  },
  {
    name: "nix-config",
    description: "My nix based configurations",
    url: "https://github.com/Hugo0Vaz/dotfiles",
    tags: ["Lua", "Shell", "Nix"],
    date: new Date("2026-06-06T21:51"),
  },
];
---

<Layout lang={currentLocale} title="Projects — hugovaz.dev">
  <h2 class="font-mono text-xl mb-6 text-primary">$ ls -la projects/</h2>

  {
    projects.length === 0 ? (
      <p class="text-primary-dim font-mono">
        total 0
      </p>
    ) : (
      <div style="font-family: 'Iosevka', monospace;">
        <p class="text-primary-dim text-sm mb-2">total {projects.length}</p>
        {projects.map((project) => (
          <div class="mb-1">
            <div class="text-sm leading-relaxed whitespace-nowrap overflow-x-auto">
              <span class="text-primary-dim">drwxr-xr-x</span>
              <span class="text-primary-dim inline-block w-6 text-right">  -</span>
              <span class="text-primary-dim ml-3">hugomvs</span>
              <span class="text-primary-dim ml-3">{fmtDate(project.date)}</span>
              <span class="ml-3">
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary font-bold no-underline hover:text-primary-dim transition-colors"
                >
                  {project.name}
                </a>
              </span>
            </div>
            <div class="text-xs text-primary-dim/60 ml-4 leading-relaxed">
              <span class="text-primary-dim/30">#</span> {project.description}
              {" "}
              {project.tags.map((tag) => (
                <span class="text-primary-dark/50">[{tag}]</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    )
  }
</Layout>
