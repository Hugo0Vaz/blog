---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "../../layouts/Layout.astro";

const currentLocale = Astro.currentLocale ?? "en";

const allPosts = await getCollection("posts");
const recentPosts = allPosts
  .filter((p) => p.data.locale === currentLocale)
  .filter((p) => import.meta.env.DEV || !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<Layout lang={currentLocale} title="hugovaz.dev">
  <h1>hugovaz.dev</h1>

  <section>
    <h2>Recent posts</h2>
    {
      recentPosts.length === 0 ? (
        <p>No posts yet.</p>
      ) : (
        <ul>
          {recentPosts.map((post) => {
            const slug = post.id.split("/").pop();
            const url = getRelativeLocaleUrl(currentLocale, `/blog/${slug}`);
            return (
              <li>
                <a href={url}>{post.data.title}</a>
                <br />
                <small>{post.data.date.toLocaleDateString(currentLocale)}</small>
              </li>
            );
          })}
        </ul>
      )
    }
  </section>
</Layout>
