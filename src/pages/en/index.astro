---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "../../layouts/Layout.astro";
import hugoImg from "../../assets/hugo.jpg";
import crypto from "node:crypto";

const currentLocale = Astro.currentLocale ?? "en";

const allPosts = await getCollection("posts");
const recentPosts = allPosts
  .filter((p) => p.data.locale === currentLocale)
  .filter((p) => import.meta.env.DEV || !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<Layout lang={currentLocale} title="hugovaz.dev">
  <!-- Hero / Intro -->
  <section class="mb-12">
    <div class="flex flex-col sm:flex-row items-start gap-6 mb-6">
      <img
        src={hugoImg.src}
        alt="Hugo"
        class="w-40 h-40 object-cover border-2 border-primary-dark shrink-0"
      />
      <p class="text-2xl text-white/80 max-w-prose leading-relaxed">
        Software developer. I write about technology, programming, and whatever else catches my interest.
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <!-- GitHub -->
      <a
        href="https://github.com/Hugo0Vaz"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 border border-primary-dark rounded-lg
               hover:bg-primary-deep transition-colors no-underline text-sm font-mono"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/hugo-vaz-dev/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 border border-primary-dark rounded-lg
               hover:bg-primary-deep transition-colors no-underline text-sm font-mono"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>
  </section>

  <!-- Recent posts (blog log --oneline) -->
  <section>
    <h2 class="font-mono text-2xl mb-4 text-primary">blog log --oneline</h2>
    {
      recentPosts.length === 0 ? (
        <p class="text-primary-dim" style="font-family: 'Iosevka', monospace;">
          fatal: no commits yet
        </p>
      ) : (
        <div class="text-sm leading-relaxed" style="font-family: 'Iosevka', monospace;">
          {recentPosts.map((post) => {
            const slug = post.id.split("/").pop();
            const url = getRelativeLocaleUrl(currentLocale, `/blog/${slug}`);
            const hash = crypto.createHash("sha1").update(slug + post.data.title).digest("hex").slice(0, 7);
            const pad = (n: number) => String(n).padStart(2, "0");
            const d = post.data.date;
            const dateStr = `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())}`;
            return (
              <a href={url} class="block no-underline text-white hover:text-primary-dim transition-colors">
                <span class="text-primary">{hash}</span> <span class="text-primary-dim">({dateStr})</span> {post.data.title}
              </a>
            );
          })}
        </div>
      )
    }
  </section>
</Layout>
