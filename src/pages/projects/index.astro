---
import Layout from "../../layouts/Layout.astro";

const currentLocale = Astro.currentLocale ?? "pt-br";

interface Project {
  name: string;
  description: string;
  url: string;
  tags: string[];
}

const projects: Project[] = [
  {
    name: "blog",
    description: "Meu site pessoal e blog feito com Astro. Aqui escrevo sobre tecnologia, programação e o que mais me interessar.",
    url: "https://github.com/Hugo0Vaz/blog",
    tags: ["Astro", "TypeScript", "TailwindCSS"],
  },
  {
    name: "DocsDog",
    description: "O melhor amigo da documentação",
    url: "https://docsdog.hugovaz.dev/",
    tags: ["TypeScript", "Documentação"],
  },
  {
    name: "nix-config",
    description: "Minhas configurações baseadas em Nix",
    url: "https://github.com/Hugo0Vaz/dotfiles",
    tags: ["Lua", "Shell", "Nix"],
  },
];
---

<Layout lang={currentLocale} title="Projetos — hugovaz.dev">
  <h2 class="font-mono text-xl mb-6 text-primary">projects ls -la</h2>

  {
    projects.length === 0 ? (
      <p class="text-primary-dim" style="font-family: 'Iosevka', monospace;">
        fatal: nenhum projeto encontrado
      </p>
    ) : (
      <div class="flex flex-col gap-8">
        {projects.map((project) => (
          <div class="border-l-2 border-primary-dark pl-4">
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-lg text-primary no-underline hover:text-primary-dim transition-colors"
            >
              {project.name}
            </a>
            <p class="text-primary-dim mt-2 text-sm leading-relaxed" style="font-family: 'Iosevka', monospace;">
              {project.description}
            </p>
            <div class="flex flex-wrap items-center gap-2 mt-3">
              {project.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 border border-primary-dark text-primary-dim rounded font-mono bg-primary-deep">
                  {tag}
                </span>
              ))}
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-xs px-2 py-0.5 border border-primary-dark text-primary-dim rounded font-mono bg-primary-deep no-underline hover:text-primary hover:border-primary transition-colors"
                title="Ver no GitHub"
              >
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                GitHub
              </a>
            </div>
          </div>
        ))}
      </div>
    )
  }
</Layout>
