---
import '../styles/global.css';
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { getRelativeLocaleUrl } from "astro:i18n";

const currentLocale = Astro.currentLocale ?? "pt-br";

const navLabels: Record<string, { blog: string; projects: string }> = {
	"pt-br": { blog: "Blog", projects: "Projetos" },
	"en": { blog: "Blog", projects: "Projects" },
};
const labels = navLabels[currentLocale] ?? navLabels["pt-br"];

interface Props {
lang: string;
title: string;
}

const { lang, title } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<header class="border-b border-primary-dark bg-primary-deep px-6 py-3 font-mono">
			<nav class="flex items-center justify-between">
				<div class="flex items-center gap-3">
					<a
						href={getRelativeLocaleUrl(currentLocale, "/")}
						class="font-mono text-2xl font-bold text-white no-underline tracking-tight"
					>
						hugovaz.dev
					</a>
				</div>
				<div class="flex items-center gap-4">
					<a href={getRelativeLocaleUrl(currentLocale, "/blog")} class="no-underline text-xl">{labels.blog}</a>
					<a href={getRelativeLocaleUrl(currentLocale, "/projects")} class="no-underline text-xl">{labels.projects}</a>
				</div>
			</nav>
		</header>
		<main class="flex-1 max-w-2xl mx-auto px-6 py-8 w-full">
			<slot />
		</main>
		<footer class="border-t border-primary-dark bg-primary-deep px-6 py-6 text-sm text-primary-dim font-mono">
			<p>&copy; 2026 Vaz Tech. No rights reserved.</p>
			<p>Contact me at: <a href="mailto:me@hugovaz.dev">me@hugovaz.dev</a></p>

			<LanguageSwitcher />
		</footer>
	</body>
</html>
